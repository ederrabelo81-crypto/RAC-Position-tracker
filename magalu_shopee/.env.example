# Supabase
SUPABASE_URL=https://ailbsczkrympslpjwwko.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Scheduling (horário UTC — 13h UTC = 10h BRT, 00h UTC = 21h BRT)
CRON_SCHEDULE=0 13,0 * * *

# Scraping
MAX_PAGES_PER_QUERY=5
BASE_DELAY_MS=2000
MAX_DELAY_MS=5000
RETRY_ATTEMPTS=3

# Rate Limiting (ms entre requests)
MAGALU_DELAY_MS=3000
SHOPEE_DELAY_MS=2000

# Output
CSV_OUTPUT_PATH=./data/rac_monitoramento.csv
LOG_LEVEL=info
