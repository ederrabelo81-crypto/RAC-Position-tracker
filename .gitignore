```gitignore
# Compiled Python files
*.pyc
__pycache__/

# Virtual environments
venv/
.venv/
.env
.env.local
*.env.*

# IDE specific files
.vscode/
.idea/
*.swp
*.swo

# Logs
*.log

# Build artifacts
dist/
build/
target/
*.out

# Dependencies
node_modules/
.mypy_cache/
.pytest_cache/
coverage/
htmlcov/
.coverage

# System files
.DS_Store
Thumbs.db
*.tmp
```