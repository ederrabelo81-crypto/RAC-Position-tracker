```gitignore
# Python compiled files
__pycache__/
*.pyc
*.pyo
*.pyd

# Dependencies
venv/
.venv/
.env
.env.local
*.env.*

# Logs and temporary files
*.log
*.tmp

# Editors and IDEs
.vscode/
.idea/
*.swp
*.swo

# Coverage and testing
.coverage
coverage/
htmlcov/
.pytest_cache/
.mypy_cache/

# Distribution artifacts
dist/
build/
target/
```