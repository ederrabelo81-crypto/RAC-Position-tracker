# .streamlit/secrets.toml.example
#
# Copie este arquivo para .streamlit/secrets.toml (nunca faça commit do original).
# No Streamlit Community Cloud use: Settings → Secrets → cole o conteúdo abaixo
# com os valores reais preenchidos.
#
# Referência: https://docs.streamlit.io/deploy/streamlit-community-cloud/deploy-your-app/secrets-management

[default]
SUPABASE_URL = "https://SEU-PROJETO.supabase.co"
SUPABASE_KEY = "sua-chave-anon-ou-service-role-aqui"
