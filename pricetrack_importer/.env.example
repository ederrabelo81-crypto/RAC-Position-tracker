# DSN do Supabase Postgres direto (não o REST endpoint)
# Pode pegar em: Supabase Dashboard → Project Settings → Database → Connection string (URI)
SUPABASE_DSN=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-REF].supabase.co:5432/postgres

# Diretório onde os exports do PriceTrack são salvos antes da importação
PRICETRACK_IMPORT_DIR=./imports/pricetrack

# Diretório de logs estruturados por execução (JSON) e unknown_sellers.log
PRICETRACK_LOG_DIR=./logs/pricetrack

# Tamanho do batch de upsert (default 1000)
PRICETRACK_BATCH_SIZE=1000
