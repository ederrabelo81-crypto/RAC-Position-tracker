{
  "name": "rac-position-tracker",
  "version": "1.0.0",
  "description": "Monitoramento automatizado de posicionamento em buscas — RAC E-Commerce Midea Brasil",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "morning": "node index.js --output both",
