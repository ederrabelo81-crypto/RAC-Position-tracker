# ── Supabase (obrigatório) ───────────────────────────────────────────────────
SUPABASE_URL=https://[YOUR-REF].supabase.co
SUPABASE_KEY=your_service_role_key

# ── Anthropic (opcional — Competitive Intelligence no dashboard) ─────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── PriceTrack API — token do header "token" ────────────────────────────────
# Encontre em: PriceTrack → Configurações → API
# NUNCA versione o valor real — use apenas o .env local (gitignored) ou
# GitHub Secrets. Se uma key já foi commitada, ROTACIONE no PriceTrack.
PRICETRACK_API_KEY=your_pricetrack_api_key

# Ajustes opcionais do cliente pricetrack_api/ (defaults de produção):
# PRICETRACK_BASE_URL=https://api.pricetrack.com.br
# PRICETRACK_EXPORT_THRESHOLD_ROWS=50000   # acima disso, coleta via export bulk
# PRICETRACK_PAGE_TAKE=100                 # take dos endpoints paginados
# PRICETRACK_MAX_RETRIES=5                 # retries com backoff exponencial
# PRICETRACK_POLL_INTERVAL_SECONDS=30      # intervalo de polling dos exports
# PRICETRACK_POLL_TIMEOUT_SECONDS=7200     # timeout por export (2h)
# PRICETRACK_MAX_CONCURRENT_EXPORTS=3      # limite da API por organização

# ── Telegram / N8N (opcional — notificações de coleta) ───────────────────────
# TELEGRAM_BOT_TOKEN=
# N8N_TELEGRAM_CHAT_ID=
# N8N_WEBHOOK_URL=

# ── Analista exibido nos relatórios (opcional) ───────────────────────────────
# ANALYST_NAME="Bot Automático Python"
